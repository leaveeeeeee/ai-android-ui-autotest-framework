<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <title>{{ case.nodeid }}</title>
  <link rel="stylesheet" href="{{ stylesheet_href }}">
</head>
<body>
  <div class="topbar"><a href="../../index.html">返回套件总览</a></div>
  <h1>{{ case.nodeid }}</h1>

  <div class="summary">
    <div>结果: <span class="status {{ case.outcome|lower }}">{{ case.outcome }} ({{ case.phase }})</span></div>
    <div>耗时: {{ case.duration }}</div>
    <div>步骤数: {{ case.steps|length }}</div>
    <div>步骤耗时: {{ case.step_duration_label }}</div>
    <div>基线定义: <code>{{ case.baseline or "-" }}</code></div>
  </div>

  <div class="summary">
    <h3>失败原因 / 环境信息</h3>
    <pre class="wrapped">{{ case.message or "-" }}</pre>
  </div>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>步骤</th>
          <th>状态</th>
          <th>步骤耗时</th>
          <th>预期</th>
          <th>实际</th>
          <th>对比</th>
          <th>步骤日志</th>
          <th>当前焦点窗口</th>
          <th>前一步截图</th>
          <th>当前截图</th>
          <th>差异图</th>
          <th>页面层级</th>
          <th>说明</th>
        </tr>
      </thead>
      <tbody>
        {% if case.steps %}
          {% for step in case.steps %}
          <tr>
            <td>{{ step.index }}</td>
            <td>{{ step.name }}</td>
            <td class="status {{ step.status|lower }}">{{ step.status }}</td>
            <td>{{ step.duration_label }}</td>
            <td>{{ step.expected }}</td>
            <td>{{ step.actual }}</td>
            <td>{{ step.comparison }}</td>
            <td><pre class="wrapped">{{ step.logs }}</pre></td>
            <td><pre class="wrapped">{{ step.focus_window }}</pre></td>
            <td>{% if step.previous_screenshot_rel %}<a href="{{ step.previous_screenshot_rel }}"><img src="{{ step.previous_screenshot_rel }}" alt="前一步截图"></a>{% else %}-{% endif %}</td>
            <td>{% if step.screenshot_rel %}<a href="{{ step.screenshot_rel }}"><img src="{{ step.screenshot_rel }}" alt="当前步骤截图"></a>{% else %}-{% endif %}</td>
            <td>{% if step.diff_rel %}<a href="{{ step.diff_rel }}"><img src="{{ step.diff_rel }}" alt="差异对比图"></a>{% else %}-{% endif %}</td>
            <td>{% if step.source_rel %}<a href="{{ step.source_rel }}">页面层级</a>{% else %}-{% endif %}</td>
            <td><pre class="wrapped">{{ step.detail }}</pre></td>
          </tr>
          {% endfor %}
        {% else %}
          <tr><td colspan="14">No step rows recorded.</td></tr>
        {% endif %}
      </tbody>
    </table>
  </div>
</body>
</html>
